{{>header}}

{{>navigation}}

<div class="row">
  <div class="leftcolumn">
    <div class="card">
      <h2>Editors</h2>
      <p>Only editors should be able to view this page!</p>
      
      <h3>Users</h3>
      <table border="1" style="width: 100%; border-collapse: collapse;">
        <tr>
          <th>Username</th>
          <th>Password</th>
          <th>Access Level</th>
        </tr>
        {{#users}}
        <tr>
          <td>{{username}}</td>
          <td>{{password}}</td>
          <td>{{level}}</td>
        </tr>
        {{/users}}
      </table>
      
      <h3>Articles</h3>
      <table border="1" style="width: 100%; border-collapse: collapse;">
        <tr>
          <th>Title</th>
          <th>Author</th>
        </tr>
        {{#articles}}
        <tr>
          <td>{{title}}</td>
          <td>{{username}}</td>
        </tr>
        {{/articles}}
      </table>
    </div>
  </div>

  {{>sidebar}}

</div>

{{>footer}}
